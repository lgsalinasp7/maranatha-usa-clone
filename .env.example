# Instagram Graph API (para la sección de feed)
# Obtén estos valores en developers.facebook.com
# Ver: https://developers.facebook.com/docs/instagram-basic-display-api

INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Para desarrollo local: copia este archivo a .env.local y rellena los valores
# Para Vercel: añade estas variables en Project Settings > Environment Variables
